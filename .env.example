# Base de Datos (PostgreSQL servidor empresa)
DATABASE_URL=postgresql://usuario:password@localhost:5432

# Auth Secret (generar con: openssl rand -base64 32)
AUTH_SECRET=dev-secret-change-in-production

# Google OAuth (crear proyecto en https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Football Data API (https://www.football-data.org/)
API_TOKEN=your-football-data-api-token
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION_ID=2000

# Aplicación
NODE_ENV=development
NUXT_PUBLIC_APP_NAME=Polla Flesan DVC

# Fecha de bloqueo fase de grupos
GROUP_PHASE_LOCK_DATE=2026-06-11T00:00:00Z

# Email API (api-notificaciones)
EMAIL_API_URL=https://apinotificaciones.grupoflesan.com/api/v1/notifications/email-custom
EMAIL_API_KEY=tu-api-key-aqui

# Live sync interval (milliseconds)
LIVE_SYNC_INTERVAL_MS=180000
